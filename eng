#!/usr/bin/env bash
#
# eng — unified CLI for eng-leader-tools
#

set -euo pipefail

VERSION="0.3.1"

# Resolve where the scripts live (follow symlinks to find real location)
SOURCE="$0"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# Strip --team and --dry-run flags from args (must happen before dispatch so subscripts don't see them)
_team_slug=""
_dry_run=false
_eng_args=()
_skip_next=false
for _arg in "$@"; do
  if [[ "$_skip_next" == "true" ]]; then
    _team_slug="$_arg"
    _skip_next=false
  elif [[ "$_arg" == "--team" ]]; then
    _skip_next=true
  elif [[ "$_arg" == --team=* ]]; then
    _team_slug="${_arg#--team=}"
  elif [[ "$_arg" == "--dry-run" ]]; then
    _dry_run=true
  else
    _eng_args+=("$_arg")
  fi
done

# Error if --team was passed without a value
if [[ "$_skip_next" == "true" ]]; then
  echo "Error: --team requires a team slug argument" >&2
  exit 1
fi

set -- "${_eng_args[@]+"${_eng_args[@]}"}"

# Use flag value, fall back to env var
_team_slug="${_team_slug:-${ENG_TEAM:-}}"

# Infer ENG_OWNER and ENG_REPO from positional owner/repo arg if present
# (skip the first arg which is the subcommand)
for _arg in "${_eng_args[@]:1}"; do
  if [[ "$_arg" == */* && "$_arg" != -* ]]; then
    export ENG_OWNER="${_arg%%/*}"
    export ENG_REPO="$_arg"
    break
  fi
done

# Auto-detect GitHub repo from git remote (only if not already set).
# Validate captured owner/repo against GitHub-allowed charset to prevent
# a malicious remote from injecting extra flags into downstream gh calls.
if [[ -z "${ENG_REPO:-}" ]]; then
  _remote_url=$(git remote get-url origin 2>/dev/null || true)
  if [[ -n "$_remote_url" ]]; then
    _remote_url="${_remote_url%.git}"
    if [[ "$_remote_url" =~ github\.com[:/]([^/]+)/(.+)$ ]]; then
      _owner="${BASH_REMATCH[1]}"
      _repo_name="${BASH_REMATCH[2]}"
      if [[ "$_owner" =~ ^[A-Za-z0-9._-]+$ && "$_repo_name" =~ ^[A-Za-z0-9._-]+$ ]]; then
        export ENG_OWNER="$_owner"
        export ENG_REPO="$_owner/$_repo_name"
      fi
    fi
  fi
fi

# Map subcommand to script filename
resolve_script() {
  case "$1" in
    lead-time)             echo "leadtimetochange.sh" ;;
    lead-time-user)        echo "leadtimetochange-user.sh" ;;
    change-failure-rate)   echo "changefailurerate.sh" ;;
    deploy-frequency)      echo "deployment-frequency.sh" ;;
    review-time)           echo "pr-review-time.sh" ;;
    pr-size)               echo "pr-size-distribution.sh" ;;
    files-per-pr)          echo "files-per-pr.sh" ;;
    files-per-pr-live)     echo "files-per-pr-live.sh" ;;
    stale-prs)             echo "stale-prs.sh" ;;
    quick-reviews)         echo "quick-reviews.sh" ;;
    review-load)           echo "review-load.sh" ;;
    code-churn)            echo "code-churn.sh" ;;
    contributor-patterns)  echo "contributor-file-patterns.sh" ;;
    lottery-factor)        echo "lottery-factor.sh" ;;
    dependency-changes)    echo "dependency-changes.sh" ;;
    contributions)         echo "track-contributions.sh" ;;
    pull-discussion)       echo "pull-discussion.sh" ;;
    analyze-discussion)    echo "analyze-discussion.sh" ;;
    *) return 1 ;;
  esac
}

show_help() {
  cat <<EOF
eng v${VERSION} — engineering leadership metrics from your terminal

Usage: eng <command> [args...]

DORA Metrics:
  lead-time              Average time from PR creation to merge
  lead-time-user         Lead time filtered to a specific contributor
  change-failure-rate    Percentage of merged PRs flagged as rollbacks/hotfixes
  deploy-frequency       How often releases/tags ship

PR Health:
  review-time            Time to first review and time to merge
  pr-size                PR size distribution (XS-XL) with review time correlation
  files-per-pr           Files changed per merged PR
  files-per-pr-live      Files changed per open PR
  stale-prs              Open PRs grouped by age
  quick-reviews          Small open PRs that need review
  review-load            Review work distribution across team members

Codebase & Contributors:
  code-churn             File hotspots — files changed repeatedly
  contributor-patterns   Per-contributor PR size patterns
  lottery-factor         Knowledge concentration risk
  dependency-changes     Dependency update tracking
  contributions          Track a user's review/comment activity

Discussion:
  pull-discussion        Pull full PR discussion as text
  analyze-discussion     Pipe discussion into LLM for summarization

Setup:
  mcp                    Install the MCP server into your AI agents

Options:
  -h, --help             Show this help
  -v, --version          Show version
  --completions SHELL    Output shell completions (bash, zsh, fish)
  --team SLUG            Filter results to members of a GitHub Team
  --dry-run              Show resolved config and command without running it

All commands support --help for detailed usage.

Created by George Mandis <george@mand.is>
https://github.com/georgemandis/eng-leader-tools
EOF
}

generate_completions() {
  local shell="$1"
  local cmds="lead-time lead-time-user change-failure-rate deploy-frequency review-time pr-size files-per-pr files-per-pr-live stale-prs quick-reviews review-load code-churn contributor-patterns lottery-factor dependency-changes contributions pull-discussion analyze-discussion mcp"

  case "$shell" in
    bash)
      cat <<EOF
_eng_completions() {
  local cur="\${COMP_WORDS[COMP_CWORD]}"
  if [[ \$COMP_CWORD -eq 1 ]]; then
    COMPREPLY=(\$(compgen -W "$cmds --help --version --completions --team" -- "\$cur"))
  elif [[ \$COMP_CWORD -ge 2 ]]; then
    COMPREPLY=(\$(compgen -W "--help --csv --team" -- "\$cur"))
  fi
}
complete -F _eng_completions eng
EOF
      ;;
    zsh)
      cat <<EOF
#compdef eng

_eng() {
  local -a commands=(
    'lead-time:Average time from PR creation to merge'
    'lead-time-user:Lead time for a specific contributor'
    'change-failure-rate:Rollback/hotfix rate'
    'deploy-frequency:Release/tag frequency'
    'review-time:Time to first review and merge'
    'pr-size:PR size distribution'
    'files-per-pr:Files changed per merged PR'
    'files-per-pr-live:Files changed per open PR'
    'stale-prs:Open PRs grouped by age'
    'quick-reviews:Small PRs needing review'
    'review-load:Review distribution across team'
    'code-churn:File change hotspots'
    'contributor-patterns:Per-contributor PR patterns'
    'lottery-factor:Knowledge concentration risk'
    'dependency-changes:Dependency update tracking'
    'contributions:User review/comment activity'
    'pull-discussion:Full PR discussion text'
    'analyze-discussion:LLM discussion summary'
    'mcp:Install the MCP server into your AI agents'
  )

  if (( CURRENT == 2 )); then
    _describe 'command' commands
  else
    _arguments '--help[Show help]' '--csv[Output as CSV]' '--team[Filter by GitHub Team]' '*:argument:_files'
  fi
}

_eng
EOF
      ;;
    fish)
      cat <<'FISHEOF'
# Fish completions for eng
set -l commands lead-time lead-time-user change-failure-rate deploy-frequency review-time pr-size files-per-pr files-per-pr-live stale-prs quick-reviews review-load code-churn contributor-patterns lottery-factor dependency-changes contributions pull-discussion analyze-discussion mcp

complete -c eng -f
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a lead-time -d "Average time from PR creation to merge"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a lead-time-user -d "Lead time for a specific contributor"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a change-failure-rate -d "Rollback/hotfix rate"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a deploy-frequency -d "Release/tag frequency"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a review-time -d "Time to first review and merge"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a pr-size -d "PR size distribution"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a files-per-pr -d "Files changed per merged PR"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a files-per-pr-live -d "Files changed per open PR"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a stale-prs -d "Open PRs grouped by age"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a quick-reviews -d "Small PRs needing review"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a review-load -d "Review distribution across team"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a code-churn -d "File change hotspots"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a contributor-patterns -d "Per-contributor PR patterns"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a lottery-factor -d "Knowledge concentration risk"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a dependency-changes -d "Dependency update tracking"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a contributions -d "User review/comment activity"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a pull-discussion -d "Full PR discussion text"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a analyze-discussion -d "LLM discussion summary"
complete -c eng -n "not __fish_seen_subcommand_from $commands" -a mcp -d "Install the MCP server into your AI agents"
complete -c eng -n "__fish_seen_subcommand_from $commands" -l help -d "Show help"
complete -c eng -n "__fish_seen_subcommand_from $commands" -l csv -d "Output as CSV"
complete -c eng -l team -d "Filter by GitHub Team"
FISHEOF
      ;;
    *)
      echo "Unsupported shell: $shell (use bash, zsh, or fish)" >&2
      exit 1
      ;;
  esac
}

# Main dispatch
case "${1:-}" in
  -h|--help|help|"")
    show_help
    ;;
  -v|--version)
    echo "eng v${VERSION}"
    ;;
  --completions)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: eng --completions <bash|zsh|fish>" >&2
      exit 1
    fi
    generate_completions "$2"
    ;;
  mcp)
    shift
    sub="${1:-install}"
    case "$sub" in
      install)
        shift 2>/dev/null || true
        export ENG_MCP_SERVER="${SCRIPT_DIR}/mcp/index.ts"
        # --dry-run is stripped by eng's global pre-processing; re-add it so
        # the installer sees it and only prints intended actions.
        if [[ "$_dry_run" == "true" ]]; then
          exec bash "${SCRIPT_DIR}/src/mcp-install.sh" "$@" --dry-run
        fi
        exec bash "${SCRIPT_DIR}/src/mcp-install.sh" "$@"
        ;;
      uninstall)
        shift 2>/dev/null || true
        export ENG_MCP_SERVER="${SCRIPT_DIR}/mcp/index.ts"
        # --dry-run is stripped by eng's global pre-processing; re-add it.
        if [[ "$_dry_run" == "true" ]]; then
          exec bash "${SCRIPT_DIR}/src/mcp-install.sh" uninstall "$@" --dry-run
        fi
        exec bash "${SCRIPT_DIR}/src/mcp-install.sh" uninstall "$@"
        ;;
      -h|--help|help|"")
        echo "Usage: eng mcp <install|uninstall> [--all] [--agent <name>] [--dry-run]"
        ;;
      *)
        echo "Unknown 'eng mcp' subcommand: $sub" >&2
        echo "Try: eng mcp install" >&2
        exit 1
        ;;
    esac
    ;;
  *)
    cmd="$1"
    shift

    script=$(resolve_script "$cmd" 2>/dev/null) || {
      echo "Unknown command: $cmd" >&2
      echo "Run 'eng --help' for available commands." >&2
      exit 1
    }

    # Resolve team members (only when dispatching a real command)
    if [[ -n "$_team_slug" ]]; then
      if [[ -z "${ENG_OWNER:-}" ]]; then
        echo "Error: --team requires an org context (run from a GitHub repo or set ENG_OWNER)" >&2
        exit 1
      fi

      export ENG_TEAM="$_team_slug"

      # Verify the owner is an org, not a user account
      _owner_type=$(gh api "/users/${ENG_OWNER}" --jq '.type' 2>/dev/null || true)
      if [[ "$_owner_type" == "User" ]]; then
        echo "Error: --team requires a GitHub organization. '${ENG_OWNER}' appears to be a user account." >&2
        exit 1
      fi

      # Check if ENG_TEAM_MEMBERS is already set (allows users to skip API call)
      if [[ -z "${ENG_TEAM_MEMBERS:-}" ]]; then
        ENG_TEAM_MEMBERS=$(gh api "/orgs/${ENG_OWNER}/teams/${_team_slug}/members" --paginate --jq '.[].login' 2>/dev/null | paste -sd, -) || {
          echo "Error: could not fetch members for team '${_team_slug}' in org '${ENG_OWNER}'" >&2
          exit 1
        }

        if [[ -z "$ENG_TEAM_MEMBERS" ]]; then
          echo "Error: team '${_team_slug}' has no members or does not exist in org '${ENG_OWNER}'" >&2
          exit 1
        fi
      fi

      export ENG_TEAM_MEMBERS
    fi

    if [[ "$_dry_run" == "true" ]]; then
      echo "eng dry-run"
      echo "─────────────────"
      echo "Command:          $cmd"
      echo "Script:           src/${script}"
      echo "Args:             $*"
      echo "ENG_REPO:         ${ENG_REPO:-<not set>}"
      echo "ENG_OWNER:        ${ENG_OWNER:-<not set>}"
      if [[ -n "${ENG_TEAM:-}" ]]; then
        echo "ENG_TEAM:         ${ENG_TEAM}"
        echo "ENG_TEAM_MEMBERS: ${ENG_TEAM_MEMBERS:-<not set>}"
      else
        echo "ENG_TEAM:         <not set>"
      fi
      exit 0
    fi

    exec bash "${SCRIPT_DIR}/src/${script}" "$@"
    ;;
esac
